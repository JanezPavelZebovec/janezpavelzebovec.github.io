" ~/.config/vim/vimrc

call plug#begin('~/.config/vim/plugged')
Plug 'morhetz/gruvbox' " doda/prenese vtičnik gruvbox iz oddaljenega repozitorija
call plug#end()

syntax on
set background=dark
colorscheme gruvbox

set mouse=a " vklop uporabe miške v vseh (a = all) načinih

set tabstop=4
set shiftwidth=4
set expandtab
set nowrap
set autoindent

set number relativenumber " vrstice so številčene v odvisnosti od trenutne

set foldmethod=indent " zlaga se glede na zamike
set foldnestmax=2 " omejitev globine gnezdenja zlaganj
set nofoldenable
set foldignore= " prezre opombe kode

map <Tab> :bn<CR>
map <S-Tab> :bp<CR>
set hidden
set splitbelow splitright " novo datoteko v razdeljenem oknu odpre pod trenutno oz. desno

" IZVRŠEVANJE DATOTEK
" Izvršljive datoteke tako lahko izvršiš s tipko F8; datoteko pred tem tudi
" shrani. V primeru markdowna in texa datoteko pretvori v PDF
autocmd FileType python map <buffer> <F8> :w<CR>:exec '!python3' shellescape(@%, 1)<CR>
autocmd FileType sh map <buffer> <F8> :w<CR>:exec '!bash' shellescape(@%, 1)<CR>
autocmd FileType markdown map <buffer> <F8> :w<CR>:exec '!pandoc -f markdown -t pdf -V papersize:a4 -o' shellescape(expand('%:r'), 1) .. '.pdf' shellescape(@%, 1)<CR>
"autocmd FileType tex map <buffer> <F8> :w<CR>:exec '!pdflatex -shell-escape' shellescape(@%, 1)<CR>
"autocmd FileType tex map <buffer> <F7> :w<CR>:!bibtex %:r<CR>
"autocmd FileType tex map <buffer> <F8> :w<CR>:!biber %:r<CR>

