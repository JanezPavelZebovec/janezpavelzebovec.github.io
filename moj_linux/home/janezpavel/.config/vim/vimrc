" autocmd FileType javascript map <S-c> :s/^\(\s*\)\(\/\/\)\@!/\1\/\/ \2<esc>
" autocmd FileType javascript map <S-s> :s/^\(\s*\)\/\/ \?\(\/\/\)\@!/\1<esc>

" autocmd FileType vim map <S-c> :s/^\(\s*\)\("\)\@!/\1" \2<esc>
" autocmd FileType vim map <S-s> :s/^\(\s*\)" \?\([^"]\)/\1\2<esc>

" autocmd FileType cpp,c nmap <S-c> :s~^\(/\=[^/]\)~// \1<esc>
" autocmd FileType cpp,c map <S-s> :s~^// ~<esc>
autocmd FileType cpp,c vmap <expr> <S-c> mode() ==# "v" ? "xi/*  */<esc>hhPlll" : ":s~^\\(/\\=[^/]\\)~// \\1<esc>"

autocmd FileType c,cpp,java,scala let b:comment_leader = '//'
autocmd FileType javascript       let b:comment_leader = '//'
autocmd FileType sh,ruby,python   let b:comment_leader = '#'
autocmd FileType tex,sty          let b:comment_leader = '%'
autocmd FileType mail             let b:comment_leader = '>'
autocmd FileType vim              let b:comment_leader = '"'
autocmd FileType sql              let b:comment_leader = '--'

" Izraz "<c-r>=b:comment_leader<cr>" uporabljen v nadaljevanju, se spremeni v vsebino spremenljivke b:comment_leader

" zakomentiraj izbrane vrstice:
map <S-c> :s@^\(\s*\)\s\@!\(<c-r>=b:comment_leader<cr>\)\@!@\1<c-r>=b:comment_leader<cr> \2<esc>
" odkomentiraj izbrane vrstice:
map <S-s> :s@^\(\s*\)<c-r>=b:comment_leader<cr> \?\([^<c-r>=b:comment_leader<cr>]\)@\1\2<esc>

" Primer s spleta:
" vnoremap <S-c> :s/^/\=b:comment_leader/g<CR>gv=
" vnoremap <S-s> :s@\V<c-r>=escape(b:comment_leader,'\@')<cr>@@<cr>gv=
autocmd FileType xml,html map <S-c> vat:s/^\(.*\)$/<!-- \1 -->/<cr>
autocmd FileType xml,html map <S-s> vatV:s/<!-- \(.*\) -->/\1/<cr>

